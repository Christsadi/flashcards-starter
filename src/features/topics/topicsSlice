import { createSlice } from '@reduxjs/toolkit';

const options = {
    name: 'topics',
    initialState: {
        topics: {},
    },
    reducers: {
        addTopic: (state, action) => {
            const { id, name, icon } = action.payload;
            state.topics[id] = {
                id: id,
                name: name,
                icon: icon,
                quizIds: []
            };
            
        }
    },
    extraReducers: {}
}

export const selectTopic = state => state.topics.topics;
export const topicsSlice = createSlice (options);
